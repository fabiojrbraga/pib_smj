# String de conexão única para MariaDB remoto
# Formato: mariadb://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL=mariadb://usuario:senha@host-remoto:3306/nome_banco

# Porta local do servidor web
PORT=3000

# IA generativa opcional para sugestao de preenchimento na grid
# A funcionalidade so sera exibida quando OPENAI_API_KEY e OPENAI_SYSTEM_PROMPT estiverem preenchidos
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_TIMEOUT_MS=20000
# CADLAN2_AI_MAX_ROWS=20
# CADLAN2_AI_MAX_EXAMPLES=4
# OPENAI_SYSTEM_PROMPT=Voce classifica lancamentos financeiros e preenche apenas lan_deslan, lan_lanope e lan_idmin quando houver base suficiente.
